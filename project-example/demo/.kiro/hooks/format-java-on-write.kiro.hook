{
  "enabled": true,
  "name": "Format Java on Write",
  "description": "Runs Spotless (Google Java Format) to auto-format Java files after a write operation is performed by the agent.",
  "version": "1",
  "when": {
    "type": "postToolUse",
    "toolTypes": [
      "write"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "gradlew.bat spotlessApply"
  },
  "workspaceFolderName": "demo",
  "shortName": "format-java-on-write"
}