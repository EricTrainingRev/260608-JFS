# Stage 1: Build the application
FROM eclipse-temurin:21-jdk AS builder
# Set the working directory for the build
WORKDIR /app
# Copy project files (filtered by .dockerignore)
COPY . .
# Make the Gradle wrapper executable and build the fat jar, skipping tests and formatting checks
RUN ./gradlew build -x test -x spotlessCheck

# Why two stages? The builder stage contains the full JDK, Gradle, and all source
# code — none of which are needed at runtime. By copying only the final jar into a
# slim JRE image, we get a much smaller, more secure production image that starts
# faster and has a reduced attack surface.

# Stage 2: Run the application
FROM eclipse-temurin:21-jre
# Set the working directory for the runtime
WORKDIR /app
# Copy only the built jar from the builder stage
COPY --from=builder /app/build/libs/demo-0.0.1-SNAPSHOT.jar app.jar
# Expose the default Spring Boot port
EXPOSE 8080
# Start the application
ENTRYPOINT ["java", "-jar", "app.jar"]
